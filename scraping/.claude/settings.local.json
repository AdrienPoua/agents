{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(mkdir:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": {
      "enabled": true,
      "commands": [
        {
          "name": "Lint TypeScript/TSX files",
          "pattern": "**/*.{ts,tsx}",
          "command": "pnpm eslint {{file}} --fix"
        },
        {
          "name": "Format with Prettier",
          "pattern": "**/*.{ts,tsx,js,jsx,json,md}",
          "command": "pnpm prettier --write {{file}}"
        },
        {
          "name": "Type check",
          "pattern": "**/*.{ts,tsx}",
          "command": "pnpm tsc --noEmit {{file}}"
        }
      ]
    },
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/adrie/.claude/song/finish.mp3"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /Users/adrie/.claude/song/need-human.mp3"
          }
        ]
      }
    ]
  }
}
